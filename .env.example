# WordPress REST API base URL — server-only.
# Used by API proxy routes, build-time Excel ingestion, and server-side fetches.
# Should NOT be NEXT_PUBLIC_* (the URL must never leak into the browser bundle
# once WP is on an internal network).
WP_API_URL=https://cmsodspr.sawangville.dev/wp-json

# (legacy) — still read as fallback by lib/wp-api.ts and scripts/convert-excel.mjs
# during migration. Remove once all environments set WP_API_URL.
# NEXT_PUBLIC_WP_API_URL=https://cmsodspr.sawangville.dev/wp-json

# Shared secret for /api/rebuild webhook. WP plugin sends this in
# Authorization: Bearer <token> header. Generate with: openssl rand -hex 32
REBUILD_TOKEN=

# Optional — override deploy script working directory (defaults to process.cwd())
# APP_DIR=/home/spr/spr-portal
